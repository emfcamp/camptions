# EMF Camptions Configuration
# Copy this file to .env and customize as needed

# Server
CAMPTIONS_HOST=0.0.0.0
CAMPTIONS_PORT=8000
CAMPTIONS_DEBUG=false

# Database
CAMPTIONS_DATABASE_URL=sqlite+aiosqlite:///./camptions.db

# WhisperLiveKit
CAMPTIONS_WHISPER_MODEL=small
CAMPTIONS_WHISPER_LANGUAGE=en
CAMPTIONS_WHISPER_BACKEND=auto
CAMPTIONS_WHISPER_BACKEND_POLICY=simulstreaming
CAMPTIONS_ENABLE_DIARIZATION=false
CAMPTIONS_ENABLE_VAD=true

# Venues (comma-separated list)
CAMPTIONS_DEFAULT_VENUES=["stage-a", "stage-b", "stage-c"]

# Retention
CAMPTIONS_CAPTION_RETENTION_HOURS=72

# Hugging Face token — required for gated models, optional for public ones (e.g. Whisper)
# HF_TOKEN=hf_...
