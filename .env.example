# EMF Camptions Configuration
# Copy this file to .env and customize as needed.

# Server
CAMPTIONS_HOST=0.0.0.0
CAMPTIONS_PORT=8000
CAMPTIONS_DEBUG=false

# Database
CAMPTIONS_DATABASE_URL=sqlite+aiosqlite:///./camptions.db

# WhisperLiveKit sidecar
CAMPTIONS_WLK_URL=ws://wlk:8000/asr

# Venues (JSON list)
CAMPTIONS_DEFAULT_VENUES=["stage-a", "stage-b", "stage-c"]

# Retention
CAMPTIONS_CAPTION_RETENTION_HOURS=72

# Hugging Face token — passed through to the WL container.
# Required only for gated models; standard Whisper models are public.
# HF_TOKEN=hf_...
