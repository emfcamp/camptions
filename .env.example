# EMF Camptions Configuration
# Copy this file to .env and customize as needed.

# Server
CAMPTIONS_HOST=0.0.0.0
CAMPTIONS_PORT=8000
CAMPTIONS_DEBUG=false

# Database
CAMPTIONS_DATABASE_URL=sqlite+aiosqlite:///./camptions.db

# WhisperLive sidecar (wl = compose service name, 9090 = WL default port)
CAMPTIONS_WL_URL=ws://wl:9090
CAMPTIONS_WHISPER_MODEL=small.en
CAMPTIONS_WHISPER_LANGUAGE=en
CAMPTIONS_WHISPER_USE_VAD=false
# Proactive WL reconnect interval (seconds). Must be < the --max_connection_time
# set on the WL container (3600 s in docker-compose.yml). The send loop drops
# and reconnects at this interval and replays the last ~5 s of audio so the
# transcriber re-enters with sentence context.
CAMPTIONS_WL_RECONNECT_INTERVAL=3300

# Auth tokens — required; all protected endpoints return 500 if unset
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
CAMPTIONS_ADMIN_TOKEN=
CAMPTIONS_INGEST_TOKEN=

# Venues (JSON list)
CAMPTIONS_DEFAULT_VENUES=["stage-a", "stage-b", "stage-c"]

# Retention
CAMPTIONS_CAPTION_RETENTION_HOURS=72

# Hugging Face token — passed through to the WL container.
# Required only for gated models; standard Whisper models are public.
#HF_TOKEN=
